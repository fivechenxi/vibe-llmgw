env: development  # development | production

server:
  port: 8080

# outbound HTTP proxy for LLM provider API calls (leave empty for direct connection)
proxy: ""

database:
  dsn: "postgres://user:password@localhost:5432/llmgw?sslmode=disable"

jwt:
  secret: "change-me-in-production"
  expire_hours: 8

sso:
  provider: "wechat_work"   # wechat_work | ldap | saml
  wechat_work:
    corp_id: ""
    agent_id: ""
    secret: ""

providers:
  openai:
    api_key: ""                                    # sk-...  or compatible key
    base_url: "https://api.openai.com/v1"          # or a compatible proxy base URL
  anthropic:
    api_key: ""                                    # sk-ant-...  or compatible key
    base_url: ""                                   # leave empty to use https://api.anthropic.com
  deepseek:
    api_key: ""
    base_url: "https://api.deepseek.com/v1"
  alibaba:
    api_key: ""                                    # sk-...
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  baidu:
    api_key: ""
    secret_key: ""
