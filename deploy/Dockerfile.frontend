# 最小前端镜像：构建 SPA + nginx 反代 /api、/auth 到宿主机后端
# 在仓库根目录执行: docker compose -f deploy/docker-compose.frontend.yml up --build
FROM node:22-alpine AS build
WORKDIR /app
COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ .
# 构建时写入：本地联调建议 true，便于 dev-login 表单
ARG VITE_ENABLE_DEV_LOGIN=true
ENV VITE_ENABLE_DEV_LOGIN=${VITE_ENABLE_DEV_LOGIN}
RUN npm run build

FROM nginx:1.27-alpine
# nginx.frontend.conf = 反代宿主机 :8080；nginx.frontend.docker.conf = 反代 Compose 内 llmgw
ARG NGINX_CONF=nginx.frontend.conf
COPY deploy/${NGINX_CONF} /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
